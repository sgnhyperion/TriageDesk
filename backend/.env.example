# Backend secrets. Copy to `backend/.env` and fill in. NEVER commit `.env`.
# Loaded automatically on backend import (see backend/__init__.py), so it works
# no matter which directory you run uvicorn from.

# --- LLM provider selection --- Member A
# Which chat provider the brain/agents use. Embeddings always use Gemini.
LLM_PROVIDER=gemini                       # gemini | anthropic

# --- Gemini (default chat provider; always used for embeddings) --- Members A & B
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash
# gemini-embedding-001 supports a configurable output dim; we request 768 to
# match the kb_chunks vector(768) column in contracts/schema.sql.
GEMINI_EMBED_MODEL=gemini-embedding-001
GEMINI_EMBED_DIM=768

# --- Anthropic / Claude (used when LLM_PROVIDER=anthropic) --- Member A
# No free tier — pay-as-you-go. claude-haiku-4-5 / claude-sonnet-4-6 are cheaper
# and accept temperature=0 (deterministic eval); claude-opus-4-8 rejects temperature.
ANTHROPIC_API_KEY=your-anthropic-api-key
ANTHROPIC_MODEL=claude-opus-4-8

# --- Database (Member B's data layer + LangGraph checkpointer) ---
# Local dev (recommended): docker compose up -d  (pgvector)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/triagedesk
# Deploy: swap to the Supabase session-pooler URI.

# --- Supabase --- (service-role key is BACKEND ONLY — never send to the browser)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# JWT validation on protected routes (Member A). Unset => auth disabled (dev mode).
# Find under Supabase: Project Settings → API → JWT Settings → JWT Secret.
SUPABASE_JWT_SECRET=your-supabase-jwt-secret
SUPABASE_JWT_AUD=authenticated

# --- Email (Resend) --- Member B
RESEND_API_KEY=your-resend-api-key
RESEND_FROM=TriageDesk <onboarding@resend.dev>

# --- Observability (LangSmith) --- optional, Member A
LANGSMITH_API_KEY=your-langsmith-key
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=triagedesk
