# Backend secrets. Copy to `backend/.env` and fill in. NEVER commit `.env`.
# Loaded automatically on backend import (see backend/__init__.py), so it works
# no matter which directory you run uvicorn from.

# --- LLM (Gemini) --- Members A & B
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash
GEMINI_EMBED_MODEL=text-embedding-004

# --- Supabase --- (service-role key is BACKEND ONLY — never send to the browser)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
DATABASE_URL=postgresql://...            # for the LangGraph Postgres checkpointer

# --- Email (Resend) --- Member B
RESEND_API_KEY=your-resend-api-key
RESEND_FROM=TriageDesk <onboarding@resend.dev>

# --- Observability (LangSmith) --- optional, Member A
LANGSMITH_API_KEY=your-langsmith-key
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=triagedesk
